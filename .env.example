# BabyGrowHelper local/deploy environment.
#
# Copy to `.env` on each machine. Never commit `.env`.

# ---- Local SQLite dev -----------------------------------------------------
BGH_DB=./data/babygrow.db

# ---- Service Postgres (Phase 2.5 family mobile MVP) -----------------------
# Set this in deploy environments. When present, migration tooling can target
# Postgres. Runtime API still defaults to SQLite unless BGH_RUNTIME_DB_BACKEND
# is set or this URL is postgres-shaped.
# BGH_DATABASE_URL=postgresql://babygrow:babygrow@localhost:5432/babygrow

# sqlite | postgres. Leave unset for local SQLite; set to postgres in the
# family trial service once migrations have been applied.
# BGH_RUNTIME_DB_BACKEND=postgres

# ---- Family access-code guard --------------------------------------------
# Local development keeps this off. Deployed family trial should set it to 1.
BGH_REQUIRE_FAMILY_AUTH=0

# Comma-separated web origins allowed to call the API. Add your LAN IP or
# deploy domain for phone testing, e.g. http://192.168.1.23:3000.
# BGH_CORS_ORIGINS=http://192.168.1.23:3000

# Public fixed-domain trial URL. Keep NEXT_PUBLIC_API_BASE=/api so the browser
# talks to the same origin and the web container proxies API calls internally.
APP_PUBLIC_HOSTNAME=app.babygrowhelper.com
NEXT_PUBLIC_API_BASE=/api
API_INTERNAL_BASE=http://api:8000

# Cloudflare named tunnel token. Create this in Cloudflare Zero Trust after
# adding the domain to Cloudflare DNS. Never commit the real token.
# CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoi...

# ---- Free fixed public URL for family trial -------------------------------
# Recommended short-term option when you do not yet own babygrowhelper.com.
# Create a free ngrok account, copy your authtoken and free Dev Domain, then
# start Docker Compose with `--profile ngrok`.
# Never commit a real NGROK_AUTHTOKEN.
# NGROK_AUTHTOKEN=2abc...
# NGROK_DOMAIN=https://your-dev-domain.ngrok-free.app

# ---- Trial feedback weekly digest ----------------------------------------
# Feedback is always persisted in Postgres first. Email is a weekly summary
# channel for the operator; missing SMTP config must not block feedback intake.
BGH_FEEDBACK_DIGEST_TO=wpb889@outlook.com
# BGH_FEEDBACK_DIGEST_FROM=babygrow@example.com
FEEDBACK_DIGEST_INTERVAL_SECONDS=604800
FEEDBACK_DIGEST_LOOKBACK_DAYS=7
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_TLS=1

# ---- Postgres backup ------------------------------------------------------
# Local dump files are written under backups/postgres by default. They are
# ignored by Git. The LaunchAgent runs at 03:15 and again on login/load; the
# script skips if a recent backup already exists.
BGH_BACKUP_RETENTION_DAYS=30
BGH_BACKUP_MIN_INTERVAL_HOURS=20
# Optional future extension point for cloud drive / object storage upload.
# Keep the real hook script and any cloud credentials outside Git.
# BGH_BACKUP_AFTER_HOOK=/absolute/path/to/private-backup-upload.sh

# The raw family code is used only for seeding/admin setup. The DB stores only
# a SHA-256 digest.
# BGH_FAMILY_ACCESS_CODE=change-me-before-deploy
BGH_FAMILY_TRIAL_MAX_FAMILIES=10

# ---- Models ---------------------------------------------------------------
BGH_LLM_BACKEND=local
BGH_OLLAMA_MODEL=qwen2.5:3b-instruct

# Required only for real cloud weekly insights / smoke tests.
# BGH_ANTHROPIC_API_KEY=sk-ant-api03-...
