# BabyGrowHelper local/deploy environment.
#
# Copy to `.env` on each machine. Never commit `.env`.

# ---- Local SQLite dev -----------------------------------------------------
BGH_DB=./data/babygrow.db

# ---- Service Postgres (Phase 2.5 family mobile MVP) -----------------------
# Set this in deploy environments. When present, migration tooling can target
# Postgres. Runtime API still defaults to SQLite unless BGH_RUNTIME_DB_BACKEND
# is set or this URL is postgres-shaped.
# BGH_DATABASE_URL=postgresql://babygrow:babygrow@localhost:5432/babygrow

# sqlite | postgres. Leave unset for local SQLite; set to postgres in the
# family trial service once migrations have been applied.
# BGH_RUNTIME_DB_BACKEND=postgres

# ---- Family access-code guard --------------------------------------------
# Local development keeps this off. Deployed family trial should set it to 1.
BGH_REQUIRE_FAMILY_AUTH=0

# The raw family code is used only for seeding/admin setup. The DB stores only
# a SHA-256 digest.
# BGH_FAMILY_ACCESS_CODE=change-me-before-deploy
BGH_FAMILY_TRIAL_MAX_FAMILIES=10

# ---- Models ---------------------------------------------------------------
BGH_LLM_BACKEND=local
BGH_OLLAMA_MODEL=qwen2.5:3b-instruct

# Required only for real cloud weekly insights / smoke tests.
# BGH_ANTHROPIC_API_KEY=sk-ant-api03-...
